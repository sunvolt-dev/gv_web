# =====================================================================
# 인스턴스별 환경변수 — 이 파일을 .env로 복사해서 값만 수정
# 멀티사이트 = 사이트별로 다른 .env (포트·DB명·사이트명·테마 분리)
# =====================================================================

# 컨테이너 식별자 (compose project name이기도 함)
INSTANCE_NAME=sunvolt

# 노출 포트
WEB_PORT=8080
DB_PORT=3307

# DB
DB_NAME=sunvolt-webpage
DB_USER=root
DB_PASS=rootpass

# (선택) 사이트 메타 오버라이드 — 비워두면 config.php 기본값 사용
SITE_NAME=
SITE_THEME=
